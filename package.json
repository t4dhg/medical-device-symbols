{
  "name": "medical-device-symbols",
  "version": "2.2.0",
  "description": "React components for ISO 15223-1:2021 medical device symbols: EU MDR/IVDR, FDA, and global labeling compliance. TypeScript, themeable, zero runtime dependencies.",
  "main": "./lib/index.js",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "generate": "node scripts/generate-index.js",
    "build": "npm run generate && tsup",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "node test-package.js && node test-icons.js",
    "prepublishOnly": "npm run build",
    "version": "npm run build",
    "postversion": "git push && git push --tags",
    "deploy": "npm run build && npm publish",
    "deploy:patch": "npm version patch && npm run deploy",
    "deploy:minor": "npm version minor && npm run deploy",
    "deploy:major": "npm version major && npm run deploy"
  },
  "keywords": [
    "medical-device",
    "symbols",
    "iso-15223-1",
    "mdr",
    "ivdr",
    "fda",
    "regulatory",
    "compliance",
    "icons",
    "svg",
    "international",
    "global",
    "medical",
    "device",
    "labeling",
    "healthcare",
    "react",
    "react-component",
    "typescript"
  ],
  "author": "Taig Mac Carthy",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "react": "^19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t4dhg/medical-device-symbols.git"
  },
  "bugs": {
    "url": "https://github.com/t4dhg/medical-device-symbols/issues"
  },
  "homepage": "https://github.com/t4dhg/medical-device-symbols#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
